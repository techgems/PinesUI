@page
@model PinesUI.LiveDemo.Pages.Spec.TypingEffectModel

@{
    ViewData["Title"] = "Typing Effect Spec";
}

<h2>Typing Effect</h2>
<p class="text-neutral-500 mb-5">The <code class="code-cell">&lt;pines-typing-effect&gt;</code> component creates a typewriter animation that cycles through an array of strings.</p>

<h3 class="mt-8 mb-3">Properties</h3>
<pines-table>
    <pines-table-header>
        <pines-table-cell>Attribute</pines-table-cell>
        <pines-table-cell>Type</pines-table-cell>
        <pines-table-cell>Default</pines-table-cell>
        <pines-table-cell>Description</pines-table-cell>
    </pines-table-header>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">text-array</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">List&lt;string&gt;</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">new List&lt;&gt;()</code></pines-table-cell>
        <pines-table-cell>Array of strings to cycle through.</pines-table-cell>
    </pines-table-row>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">type-speed</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">int</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">110</code></pines-table-cell>
        <pines-table-cell>Milliseconds between each character typed.</pines-table-cell>
    </pines-table-row>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">cursor-speed</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">int</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">550</code></pines-table-cell>
        <pines-table-cell>Cursor blink speed in milliseconds.</pines-table-cell>
    </pines-table-row>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">pause-end</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">int</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">1500</code></pines-table-cell>
        <pines-table-cell>Pause duration after finishing a string (ms).</pines-table-cell>
    </pines-table-row>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">pause-start</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">int</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">20</code></pines-table-cell>
        <pines-table-cell>Pause duration before starting a new string (ms).</pines-table-cell>
    </pines-table-row>
</pines-table>
