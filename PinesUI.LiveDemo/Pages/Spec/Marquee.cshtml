@page
@model PinesUI.LiveDemo.Pages.Spec.MarqueeModel

@{
    ViewData["Title"] = "Marquee Spec";
}

<h2>Marquee</h2>
<p class="text-neutral-500 mb-5">The <code class="code-cell">&lt;pines-marquee&gt;</code> component renders its child content in a continuously scrolling horizontal loop. Use it to display partner logos, announcement tickers, feature highlights, or any content that benefits from a smooth, auto-scrolling presentation. Place any valid HTML or text inside the component — it requires no configuration.</p>
