@page
@model PinesUI.LiveDemo.Pages.Spec.FormsModel

@{
    ViewData["Title"] = "Forms Spec";
}

<h2>Forms</h2>
<p class="text-neutral-500 mb-5">Form components for building interactive forms including text inputs, toggle switches, select dropdowns, and date pickers.</p>

<h3 class="mt-8 mb-3">&lt;pines-input&gt; Properties</h3>
<pines-table>
    <pines-table-header>
        <pines-table-cell>Attribute</pines-table-cell>
        <pines-table-cell>Type</pines-table-cell>
        <pines-table-cell>Description</pines-table-cell>
    </pines-table-header>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">asp-for</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">ModelExpression?</code></pines-table-cell>
        <pines-table-cell>Model binding expression.</pines-table-cell>
    </pines-table-row>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">show-label</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">bool</code></pines-table-cell>
        <pines-table-cell>Whether to display the field label.</pines-table-cell>
    </pines-table-row>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">disabled</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">bool</code></pines-table-cell>
        <pines-table-cell>Whether the input is disabled.</pines-table-cell>
    </pines-table-row>
</pines-table>

