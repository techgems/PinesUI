@page
@model PinesUI.LiveDemo.Pages.Spec.CardsModel

@{
    ViewData["Title"] = "Cards Spec";
}

<h2>Cards</h2>
<p class="text-neutral-500 mb-5">The <code class="code-cell">&lt;pines-image-card&gt;</code> component renders a visually framed content block combining an image with a title and optional body content. Use it to present items in grid or list layouts — such as product listings, team member profiles, portfolio entries, or news articles — where each item benefits from a visual thumbnail paired with descriptive text.</p>

<h3 class="mt-8 mb-3">Properties</h3>
<pines-table>
    <pines-table-header>
        <pines-table-cell>Attribute</pines-table-cell>
        <pines-table-cell>Type</pines-table-cell>
        <pines-table-cell>Description</pines-table-cell>
    </pines-table-header>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">image-url</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">string</code></pines-table-cell>
        <pines-table-cell>URL of the image displayed at the top of the card. Use a high-quality image that represents the card's subject — thumbnails, avatars, product photos, or cover images work well here.</pines-table-cell>
    </pines-table-row>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">title</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">string</code></pines-table-cell>
        <pines-table-cell>Primary heading displayed below the image. Keep it concise and descriptive — it is the first text the user reads and should clearly identify the card's content.</pines-table-cell>
    </pines-table-row>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">class</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">string</code></pines-table-cell>
        <pines-table-cell>Additional CSS classes applied to the card container. Use to control width, spacing, or shadow within a parent grid or flex layout.</pines-table-cell>
    </pines-table-row>
</pines-table>

<h3 class="mt-8 mb-3">Named Slots</h3>
<pines-table>
    <pines-table-header>
        <pines-table-cell>Slot Name</pines-table-cell>
        <pines-table-cell>Description</pines-table-cell>
    </pines-table-header>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">CardContent_Slot</code></pines-table-cell>
        <pines-table-cell>Custom content rendered as the card body.</pines-table-cell>
    </pines-table-row>
</pines-table>
