@page
@model PinesUI.LiveDemo.Pages.Spec.BadgeModel

@{
    ViewData["Title"] = "Badge Spec";
}

<h2>Badge</h2>
<p class="text-neutral-500 mb-5">The <code class="code-cell">&lt;pines-badge&gt;</code> component renders a small inline label with configurable style and color. Child content is used as the badge label text.</p>

<h3 class="mt-8 mb-3">Properties</h3>
<pines-table>
    <pines-table-header>
        <pines-table-cell>Attribute</pines-table-cell>
        <pines-table-cell>Type</pines-table-cell>
        <pines-table-cell>Description</pines-table-cell>
    </pines-table-header>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">type</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">BadgeType</code></pines-table-cell>
        <pines-table-cell>The badge style variant.</pines-table-cell>
    </pines-table-row>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">color</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">BadgeColor</code></pines-table-cell>
        <pines-table-cell>The color scheme.</pines-table-cell>
    </pines-table-row>
</pines-table>

<h3 class="mt-8 mb-3">BadgeType Values</h3>
<pines-table>
    <pines-table-header>
        <pines-table-cell>Value</pines-table-cell>
        <pines-table-cell>Description</pines-table-cell>
    </pines-table-header>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">Primary</code></pines-table-cell>
        <pines-table-cell>Primary style variant.</pines-table-cell>
    </pines-table-row>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">Secondary</code></pines-table-cell>
        <pines-table-cell>Secondary style variant.</pines-table-cell>
    </pines-table-row>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">Outlined</code></pines-table-cell>
        <pines-table-cell>Outlined style variant.</pines-table-cell>
    </pines-table-row>
</pines-table>

<h3 class="mt-8 mb-3">BadgeColor Values</h3>
<pines-table>
    <pines-table-header>
        <pines-table-cell>Value</pines-table-cell>
        <pines-table-cell>Description</pines-table-cell>
    </pines-table-header>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">Neutral</code></pines-table-cell>
        <pines-table-cell>Neutral color scheme.</pines-table-cell>
    </pines-table-row>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">Blue</code></pines-table-cell>
        <pines-table-cell>Blue color scheme.</pines-table-cell>
    </pines-table-row>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">Red</code></pines-table-cell>
        <pines-table-cell>Red color scheme.</pines-table-cell>
    </pines-table-row>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">Yellow</code></pines-table-cell>
        <pines-table-cell>Yellow color scheme.</pines-table-cell>
    </pines-table-row>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">Purple</code></pines-table-cell>
        <pines-table-cell>Purple color scheme.</pines-table-cell>
    </pines-table-row>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">Green</code></pines-table-cell>
        <pines-table-cell>Green color scheme.</pines-table-cell>
    </pines-table-row>
</pines-table>
