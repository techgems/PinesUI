@page
@model PinesUI.LiveDemo.Pages.Spec.QuoteModel

@{
    ViewData["Title"] = "Quote Spec";
}

<h2>Quote</h2>
<p class="text-neutral-500 mb-5">The <code class="code-cell">&lt;pines-quote&gt;</code> component displays a styled blockquote with author attribution and optional profile image. Child content is used as the quote text.</p>

<h3 class="mt-8 mb-3">Properties</h3>
<pines-table>
    <pines-table-header>
        <pines-table-cell>Attribute</pines-table-cell>
        <pines-table-cell>Type</pines-table-cell>
        <pines-table-cell>Description</pines-table-cell>
    </pines-table-header>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">author</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">string</code></pines-table-cell>
        <pines-table-cell>The quote author's name.</pines-table-cell>
    </pines-table-row>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">author-title</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">string?</code></pines-table-cell>
        <pines-table-cell>The author's title or role.</pines-table-cell>
    </pines-table-row>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">image-url</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">string?</code></pines-table-cell>
        <pines-table-cell>URL for the author's profile image.</pines-table-cell>
    </pines-table-row>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">image-alt</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">string?</code></pines-table-cell>
        <pines-table-cell>Alt text for the profile image.</pines-table-cell>
    </pines-table-row>
</pines-table>
