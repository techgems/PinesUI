@page
@model PinesUI.LiveDemo.Pages.Spec.BannerModel

@{
    ViewData["Title"] = "Banner Spec";
}

<h2>Banner</h2>
<p class="text-neutral-500 mb-5">The <code class="code-cell">&lt;pines-banner&gt;</code> component renders a full-width notification strip, typically placed at the top of a page or section. Use it for site-wide announcements, promotional messages, system maintenance notices, or any message that needs to reach all users regardless of where they are in the application.</p>

<h3 class="mt-8 mb-3">Properties</h3>
<pines-table>
    <pines-table-header>
        <pines-table-cell>Attribute</pines-table-cell>
        <pines-table-cell>Type</pines-table-cell>
        <pines-table-cell>Description</pines-table-cell>
    </pines-table-header>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">head</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">string</code></pines-table-cell>
        <pines-table-cell>Short, bold headline displayed prominently in the banner. Use a concise phrase that immediately communicates the subject — for example, "Scheduled Maintenance" or "Free Shipping This Weekend".</pines-table-cell>
    </pines-table-row>
    <pines-table-row>
        <pines-table-cell><code class="code-cell">body</code></pines-table-cell>
        <pines-table-cell><code class="code-cell">string</code></pines-table-cell>
        <pines-table-cell>Supporting text that elaborates on the headline. Use to provide details, instructions, or a call to action that gives context to the heading.</pines-table-cell>
    </pines-table-row>
</pines-table>
