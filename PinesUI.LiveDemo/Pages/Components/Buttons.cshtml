@page
@using System.Text
@using TechGems.PinesUI.Views.Components.PinesTabs
@model PinesUI.LiveDemo.Pages.Components.ButtonsModel

@{
    ViewData["Title"] = "Buttons";

    var tabConfig = new Dictionary<string, PinesTabConfigItem>()
    {
        { "Preview", new PinesTabConfigItem { TabName = "Preview", Order = 1 } },
        { "Code", new PinesTabConfigItem { TabName = "Code", Order = 2 } },
    };

    StringBuilder codeCreator = new StringBuilder();

    // Primary Buttons code
    codeCreator.AppendLine(@"<div class=""flex flex-wrap gap-3"">");
    codeCreator.AppendLine(@"    <pines-button type=""Primary"" color=""Neutral"">Neutral</pines-button>");
    codeCreator.AppendLine(@"    <pines-button type=""Primary"" color=""Black"">Black</pines-button>");
    codeCreator.AppendLine(@"    <pines-button type=""Primary"" color=""Blue"">Blue</pines-button>");
    codeCreator.AppendLine(@"    <pines-button type=""Primary"" color=""Red"">Red</pines-button>");
    codeCreator.AppendLine(@"    <pines-button type=""Primary"" color=""Green"">Green</pines-button>");
    codeCreator.AppendLine(@"    <pines-button type=""Primary"" color=""Yellow"">Yellow</pines-button>");
    codeCreator.AppendLine(@"</div>");
    var primaryButtonsCode = codeCreator.ToString();
    codeCreator.Clear();

    // Secondary Buttons code
    codeCreator.AppendLine(@"<div class=""flex flex-wrap gap-3"">");
    codeCreator.AppendLine(@"    <pines-button type=""Secondary"" color=""Neutral"">Neutral</pines-button>");
    codeCreator.AppendLine(@"    <pines-button type=""Secondary"" color=""Black"">Black</pines-button>");
    codeCreator.AppendLine(@"    <pines-button type=""Secondary"" color=""Blue"">Blue</pines-button>");
    codeCreator.AppendLine(@"    <pines-button type=""Secondary"" color=""Red"">Red</pines-button>");
    codeCreator.AppendLine(@"    <pines-button type=""Secondary"" color=""Green"">Green</pines-button>");
    codeCreator.AppendLine(@"    <pines-button type=""Secondary"" color=""Yellow"">Yellow</pines-button>");
    codeCreator.AppendLine(@"</div>");
    var secondaryButtonsCode = codeCreator.ToString();
    codeCreator.Clear();

    // Outlined Buttons code
    codeCreator.AppendLine(@"<div class=""flex flex-wrap gap-3"">");
    codeCreator.AppendLine(@"    <pines-button type=""Outlined"" color=""Neutral"">Neutral</pines-button>");
    codeCreator.AppendLine(@"    <pines-button type=""Outlined"" color=""Black"">Black</pines-button>");
    codeCreator.AppendLine(@"    <pines-button type=""Outlined"" color=""Blue"">Blue</pines-button>");
    codeCreator.AppendLine(@"    <pines-button type=""Outlined"" color=""Red"">Red</pines-button>");
    codeCreator.AppendLine(@"    <pines-button type=""Outlined"" color=""Green"">Green</pines-button>");
    codeCreator.AppendLine(@"    <pines-button type=""Outlined"" color=""Yellow"">Yellow</pines-button>");
    codeCreator.AppendLine(@"</div>");
    var outlinedButtonsCode = codeCreator.ToString();
    codeCreator.Clear();

    // Shadow Button code
    codeCreator.AppendLine(@"<pines-shadow-button>Shadow Button</pines-shadow-button>");
    var shadowButtonCode = codeCreator.ToString();
    codeCreator.Clear();


}

<h2>Buttons</h2>
<p class="text-neutral-500 mb-5">Clickable elements for actions and navigation, available in multiple styles and colors.</p>

<h3>Primary Buttons</h3>
<pines-tabs tab-config="tabConfig">
    <slot name="Preview">
        <div class="flex flex-wrap gap-3">
            <pines-button type="Primary" color="Neutral">Neutral</pines-button>
            <pines-button type="Primary" color="Black">Black</pines-button>
            <pines-button type="Primary" color="Blue">Blue</pines-button>
            <pines-button type="Primary" color="Red">Red</pines-button>
            <pines-button type="Primary" color="Green">Green</pines-button>
            <pines-button type="Primary" color="Yellow">Yellow</pines-button>
        </div>
    </slot>
    <slot name="Code">
        <code-highlight lang="html" code="@primaryButtonsCode"></code-highlight>
    </slot>
</pines-tabs>

<h3>Secondary Buttons</h3>
<pines-tabs tab-config="tabConfig">
    <slot name="Preview">
        <div class="flex flex-wrap gap-3">
            <pines-button type="Secondary" color="Neutral">Neutral</pines-button>
            <pines-button type="Secondary" color="Black">Black</pines-button>
            <pines-button type="Secondary" color="Blue">Blue</pines-button>
            <pines-button type="Secondary" color="Red">Red</pines-button>
            <pines-button type="Secondary" color="Green">Green</pines-button>
            <pines-button type="Secondary" color="Yellow">Yellow</pines-button>
        </div>
    </slot>
    <slot name="Code">
        <code-highlight lang="html" code="@secondaryButtonsCode"></code-highlight>
    </slot>
</pines-tabs>

<h3>Outlined Buttons</h3>
<pines-tabs tab-config="tabConfig">
    <slot name="Preview">
        <div class="flex flex-wrap gap-3">
            <pines-button type="Outlined" color="Neutral">Neutral</pines-button>
            <pines-button type="Outlined" color="Black">Black</pines-button>
            <pines-button type="Outlined" color="Blue">Blue</pines-button>
            <pines-button type="Outlined" color="Red">Red</pines-button>
            <pines-button type="Outlined" color="Green">Green</pines-button>
            <pines-button type="Outlined" color="Yellow">Yellow</pines-button>
        </div>
    </slot>
    <slot name="Code">
        <code-highlight lang="html" code="@outlinedButtonsCode"></code-highlight>
    </slot>
</pines-tabs>

<h3>Parameters — <code>&lt;pines-button&gt;</code></h3>
<pines-table table-id="button-params">
    <pines-table-header>
        <pines-table-cell is-header="true">Attribute</pines-table-cell>
        <pines-table-cell is-header="true">Type</pines-table-cell>
        <pines-table-cell is-header="true">Description</pines-table-cell>
    </pines-table-header>
    <tbody class="divide-y divide-neutral-200">
        <pines-table-row>
            <pines-table-cell>type</pines-table-cell>
            <pines-table-cell>PinesButtonTypeEnum: Primary | Secondary | Outlined</pines-table-cell>
            <pines-table-cell>Button style variant.</pines-table-cell>
        </pines-table-row>
        <pines-table-row>
            <pines-table-cell>color</pines-table-cell>
            <pines-table-cell>PinesButtonColorEnum: Neutral | Black | Blue | Red | Green | Yellow</pines-table-cell>
            <pines-table-cell>Button color.</pines-table-cell>
        </pines-table-row>
    </tbody>
</pines-table>
<p class="text-neutral-500 text-sm mt-2 mb-8">Button text is set by using child content.</p>

<h3>Shadow Button</h3>
<pines-tabs tab-config="tabConfig">
    <slot name="Preview">
        <pines-shadow-button>Shadow Button</pines-shadow-button>
    </slot>
    <slot name="Code">
        <code-highlight lang="html" code="@shadowButtonCode"></code-highlight>
    </slot>
</pines-tabs>

<h3>Parameters — <code>&lt;pines-shadow-button&gt;</code></h3>
<p class="text-neutral-500 text-sm mb-8">No parameters. Button text is set by using child content.</p>




