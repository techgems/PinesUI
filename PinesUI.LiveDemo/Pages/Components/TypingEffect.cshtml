@page
@using System.Text
@using TechGems.PinesUI.Views.Components.PinesTabs
@model PinesUI.LiveDemo.Pages.Components.TypingEffectModel

@{
    ViewData["Title"] = "Typing Effect";

    var tabConfig = new Dictionary<string, PinesTabConfigItem>()
    {
        { "Preview", new PinesTabConfigItem { TabName = "Preview", Order = 1 } },
        { "Code", new PinesTabConfigItem { TabName = "Code", Order = 2 } },
    };

    var typingTexts = new List<string>() { "Hello World", "Welcome to Pines UI", "Built with Alpine.js" };
    var fastTexts = new List<string>() { "Fast typing", "Quick animation", "Speed demo" };

    StringBuilder codeCreator = new StringBuilder();
    codeCreator.AppendLine(@"  @{");
    codeCreator.AppendLine(@"      var typingTexts = new List<string>() { ""Hello World"", ""Welcome to Pines UI"", ""Built with Alpine.js"" };");
    codeCreator.AppendLine(@"  }");
    codeCreator.AppendLine(@"");
    codeCreator.AppendLine(@"  <pines-typing-effect text-array=""typingTexts""></pines-typing-effect>");

    var defaultSpeedCode = codeCreator.ToString();
    codeCreator.Clear();

    codeCreator.AppendLine(@"  @{");
    codeCreator.AppendLine(@"      var fastTexts = new List<string>() { ""Fast typing"", ""Quick animation"", ""Speed demo"" };");
    codeCreator.AppendLine(@"  }");
    codeCreator.AppendLine(@"");
    codeCreator.AppendLine(@"  <pines-typing-effect text-array=""fastTexts"" type-speed=""50"" pause-end=""800""></pines-typing-effect>");

    var fastTypingCode = codeCreator.ToString();
    codeCreator.Clear();

}

<h2>Typing Effect</h2>
<p class="text-neutral-500 mb-5">Typewriter-style text animation that cycles through an array of strings.</p>

<h3>Default Speed</h3>

<pines-tabs tab-config="tabConfig">
    <slot name="Preview">
        <pines-typing-effect text-array="typingTexts"></pines-typing-effect>
    </slot>
    <slot name="Code">
        <code-highlight lang="html" code="@defaultSpeedCode"></code-highlight>
    </slot>
</pines-tabs>

<h3>Parameters</h3>
<pines-table table-id="typing-effect-params">
    <pines-table-header>
        <pines-table-cell is-header="true">Attribute</pines-table-cell>
        <pines-table-cell is-header="true">Type</pines-table-cell>
        <pines-table-cell is-header="true">Default</pines-table-cell>
        <pines-table-cell is-header="true">Description</pines-table-cell>
    </pines-table-header>
    <tbody class="divide-y divide-neutral-200">
        <pines-table-row>
            <pines-table-cell>text-array</pines-table-cell>
            <pines-table-cell>List&lt;string&gt;</pines-table-cell>
            <pines-table-cell>new List&lt;&gt;()</pines-table-cell>
            <pines-table-cell>Strings to cycle through.</pines-table-cell>
        </pines-table-row>
        <pines-table-row>
            <pines-table-cell>type-speed</pines-table-cell>
            <pines-table-cell>int</pines-table-cell>
            <pines-table-cell>110</pines-table-cell>
            <pines-table-cell>Typing speed in milliseconds per character.</pines-table-cell>
        </pines-table-row>
        <pines-table-row>
            <pines-table-cell>cursor-speed</pines-table-cell>
            <pines-table-cell>int</pines-table-cell>
            <pines-table-cell>550</pines-table-cell>
            <pines-table-cell>Cursor blink interval in milliseconds.</pines-table-cell>
        </pines-table-row>
        <pines-table-row>
            <pines-table-cell>pause-end</pines-table-cell>
            <pines-table-cell>int</pines-table-cell>
            <pines-table-cell>1500</pines-table-cell>
            <pines-table-cell>Pause duration after finishing a string (ms).</pines-table-cell>
        </pines-table-row>
        <pines-table-row>
            <pines-table-cell>pause-start</pines-table-cell>
            <pines-table-cell>int</pines-table-cell>
            <pines-table-cell>20</pines-table-cell>
            <pines-table-cell>Pause duration before starting to type (ms).</pines-table-cell>
        </pines-table-row>
    </tbody>
</pines-table>

<h3>Fast Typing</h3>

<pines-tabs tab-config="tabConfig">
    <slot name="Preview">
        <pines-typing-effect text-array="fastTexts" type-speed="50" pause-end="800"></pines-typing-effect>
    </slot>
    <slot name="Code">
        <code-highlight lang="html" code="@fastTypingCode"></code-highlight>
    </slot>
</pines-tabs>
