@page
@using System.Text
@using TechGems.PinesUI.Views.Components.PinesTabs
@model PinesUI.LiveDemo.Pages.Components.BreadcrumbsModel

@{
    ViewData["Title"] = "Breadcrumbs";

    var tabConfig = new Dictionary<string, PinesTabConfigItem>()
    {
        { "Preview", new PinesTabConfigItem { TabName = "Preview", Order = 1 } },
        { "Code", new PinesTabConfigItem { TabName = "Code", Order = 2 } },
    };

    StringBuilder codeCreator = new StringBuilder();
    codeCreator.AppendLine(@"  <pines-breadcrumb>");
    codeCreator.AppendLine(@"    <pines-breadcrumb-item asp-page=""/Index"" is-first=""true"" has-next=""true"">Home</pines-breadcrumb-item>");
    codeCreator.AppendLine(@"    <pines-breadcrumb-item asp-page=""/Components/Alerts"" has-next=""true"">Components</pines-breadcrumb-item>");
    codeCreator.AppendLine(@"    <pines-breadcrumb-item>Breadcrumbs</pines-breadcrumb-item>");
    codeCreator.AppendLine(@"  </pines-breadcrumb>");

    var breadcrumbsCode = codeCreator.ToString();
    codeCreator.Clear();
}

<h2>Breadcrumbs</h2>
<p class="text-neutral-500 mb-5">Navigation aid showing the user's current location within a site hierarchy.</p>

<h3>Breadcrumbs</h3>

<pines-tabs tab-config="tabConfig">
    <slot name="Preview">
        <pines-breadcrumb>
            <pines-breadcrumb-item asp-page="/Index" is-first="true" has-next="true">Home</pines-breadcrumb-item>
            <pines-breadcrumb-item asp-page="/Components/Alerts" has-next="true">Components</pines-breadcrumb-item>
            <pines-breadcrumb-item>Breadcrumbs</pines-breadcrumb-item>
        </pines-breadcrumb>
    </slot>
    <slot name="Code">
        <code-highlight lang="html" code="@breadcrumbsCode"></code-highlight>
    </slot>
</pines-tabs>

<h3>Parameters — <code>&lt;pines-breadcrumb-item&gt;</code></h3>
<p class="text-neutral-500 text-sm mt-2 mb-8">No parameters. This component is a wrapper for <code>&lt;pines-breadcrumb-item&gt;</code></p>

<h3>Parameters — <code>&lt;pines-breadcrumb-item&gt;</code></h3>
<pines-table table-id="breadcrumb-item-params">
    <pines-table-header>
        <pines-table-cell is-header="true">Attribute</pines-table-cell>
        <pines-table-cell is-header="true">Type</pines-table-cell>
        <pines-table-cell is-header="true">Default</pines-table-cell>
        <pines-table-cell is-header="true">Description</pines-table-cell>
    </pines-table-header>
    <tbody class="divide-y divide-neutral-200">
        <pines-table-row>
            <pines-table-cell>is-first</pines-table-cell>
            <pines-table-cell>bool</pines-table-cell>
            <pines-table-cell>false</pines-table-cell>
            <pines-table-cell>Whether this is the first breadcrumb (shows home icon).</pines-table-cell>
        </pines-table-row>
        <pines-table-row>
            <pines-table-cell>has-next</pines-table-cell>
            <pines-table-cell>bool</pines-table-cell>
            <pines-table-cell>false</pines-table-cell>
            <pines-table-cell>Whether a separator should appear after this item.</pines-table-cell>
        </pines-table-row>
        <pines-table-row>
            <pines-table-cell>asp-page</pines-table-cell>
            <pines-table-cell>string?</pines-table-cell>
            <pines-table-cell>N/A</pines-table-cell>
            <pines-table-cell>Razor page route link. If this field is set, do not use asp-controller and asp-action.</pines-table-cell>
        </pines-table-row>
        <pines-table-row>
            <pines-table-cell>asp-controller</pines-table-cell>
            <pines-table-cell>string?</pines-table-cell>
            <pines-table-cell>N/A</pines-table-cell>
            <pines-table-cell>MVC controller link. If this field is set, do not use asp-page.</pines-table-cell>
        </pines-table-row>
        <pines-table-row>
            <pines-table-cell>asp-action</pines-table-cell>
            <pines-table-cell>string?</pines-table-cell>
            <pines-table-cell>N/A</pines-table-cell>
            <pines-table-cell>MVC action link. If this field is set, do not use asp-page.</pines-table-cell>
        </pines-table-row>
    </tbody>
</pines-table>
<p class="text-neutral-500 text-sm mt-2 mb-8">This component sets content by using child content.</p>
