@page
@using System.Text
@using TechGems.PinesUI.Views.Components.PinesTabs
@model PinesUI.LiveDemo.Pages.Components.AlertsModel

@{
    ViewData["Title"] = "Alerts";

    var tabConfig = new Dictionary<string, PinesTabConfigItem>()
    {
        { "Preview", new PinesTabConfigItem { TabName = "Preview", Order = 1 } },
        { "Code", new PinesTabConfigItem { TabName = "Code", Order = 2 } },
    };

    StringBuilder codeCreator = new StringBuilder();
    codeCreator.AppendLine(@"  <pines-alert type=""Primary"" color=""Blue"" header=""Alert Message Headline"">");
    codeCreator.AppendLine(@"    This is the subtext for your alert message, providing important information or instructions.");
    codeCreator.AppendLine(@"  </pines-alert>");
    codeCreator.AppendLine(@"");
    codeCreator.AppendLine(@"  <pines-alert type=""Primary"" color=""Red"" header=""Alert Message Headline"">");
    codeCreator.AppendLine(@"    This is the subtext for your alert message, providing important information or instructions.");
    codeCreator.AppendLine(@"  </pines-alert>");
    codeCreator.AppendLine(@"");
    codeCreator.AppendLine(@"  <pines-alert type=""Primary"" color=""Yellow"" header=""Alert Message Headline"">");
    codeCreator.AppendLine(@"    This is the subtext for your alert message, providing important information or instructions.");
    codeCreator.AppendLine(@"  </pines-alert>");
    codeCreator.AppendLine(@"");
    codeCreator.AppendLine(@"  <pines-alert type=""Primary"" color=""Green"" header=""Alert Message Headline"">");
    codeCreator.AppendLine(@"    This is the subtext for your alert message, providing important information or instructions.");
    codeCreator.AppendLine(@"  </pines-alert>");

    var primaryAlertsCode = codeCreator.ToString();
    codeCreator.Clear();


    codeCreator.AppendLine(@"  <pines-alert type=""Secondary"" color=""Blue"" header=""Alert Message Headline"">");
    codeCreator.AppendLine(@"    This is the subtext for your alert message, providing important information or instructions.");
    codeCreator.AppendLine(@"  </pines-alert>");
    codeCreator.AppendLine(@"");
    codeCreator.AppendLine(@"  <pines-alert type=""Secondary"" color=""Red"" header=""Alert Message Headline"">");
    codeCreator.AppendLine(@"    This is the subtext for your alert message, providing important information or instructions.");
    codeCreator.AppendLine(@"  </pines-alert>");
    codeCreator.AppendLine(@"");
    codeCreator.AppendLine(@"  <pines-alert type=""Secondary"" color=""Yellow"" header=""Alert Message Headline"">");
    codeCreator.AppendLine(@"    This is the subtext for your alert message, providing important information or instructions.");
    codeCreator.AppendLine(@"  </pines-alert>");
    codeCreator.AppendLine(@"");
    codeCreator.AppendLine(@"  <pines-alert type=""Secondary"" color=""Green"" header=""Alert Message Headline"">");
    codeCreator.AppendLine(@"    This is the subtext for your alert message, providing important information or instructions.");
    codeCreator.AppendLine(@"  </pines-alert>");

    var secondaryAlertsCode = codeCreator.ToString();
    codeCreator.Clear();

}

<h2>Alerts</h2>
<p class="text-neutral-500 mb-5">Contextual feedback messages for user actions, available in multiple colors and styles.</p>

<h3>Primary Alerts</h3>

<pines-tabs tab-config="tabConfig">
    <slot name="Preview">
        <pines-alert type="Primary" color="Blue" header="Alert Message Headline" class="mb-5">
            This is the subtext for your alert message, providing important information or instructions.
        </pines-alert>

        <pines-alert type="Primary" color="Red" header="Alert Message Headline" class="mb-5">
            This is the subtext for your alert message, providing important information or instructions.
        </pines-alert>

        <pines-alert type="Primary" color="Yellow" header="Alert Message Headline" class="mb-5">
            This is the subtext for your alert message, providing important information or instructions.
        </pines-alert>

        <pines-alert type="Primary" color="Green" header="Alert Message Headline" class="mb-5">
            This is the subtext for your alert message, providing important information or instructions.
        </pines-alert>
    </slot>
    <slot name="Code">
        <code-highlight lang="html" code="@primaryAlertsCode"></code-highlight>
    </slot>
</pines-tabs>

<h3>Secondary Alerts</h3>

<pines-tabs tab-config="tabConfig">
    <slot name="Preview">
        <pines-alert type="Secondary" color="Blue" header="Alert Message Headline" class="mb-5">
            This is the subtext for your alert message, providing important information or instructions.
        </pines-alert>

        <pines-alert type="Secondary" color="Red" header="Alert Message Headline" class="mb-5">
            This is the subtext for your alert message, providing important information or instructions.
        </pines-alert>

        <pines-alert type="Secondary" color="Yellow" header="Alert Message Headline" class="mb-5">
            This is the subtext for your alert message, providing important information or instructions.
        </pines-alert>

        <pines-alert type="Secondary" color="Green" header="Alert Message Headline" class="mb-5">
            This is the subtext for your alert message, providing important information or instructions.
        </pines-alert>
    </slot>
    <slot name="Code">
        <code-highlight lang="html" code="@primaryAlertsCode"></code-highlight>
    </slot>
</pines-tabs>

<h3>Parameters</h3>
<pines-table table-id="alert-params">
    <pines-table-header>
        <pines-table-cell is-header="true">Attribute</pines-table-cell>
        <pines-table-cell is-header="true">Type</pines-table-cell>
        <pines-table-cell is-header="true">Description</pines-table-cell>
    </pines-table-header>
    <tbody class="divide-y divide-neutral-200">
        <pines-table-row>
            <pines-table-cell>type</pines-table-cell>
            <pines-table-cell>PinesAlertTypeEnum: Primary | Secondary | Neutral</pines-table-cell>
            <pines-table-cell>The style variant of the alert.</pines-table-cell>
        </pines-table-row>
        <pines-table-row>
            <pines-table-cell>color</pines-table-cell>
            <pines-table-cell>PinesAlertColorEnum: Blue | Red | Green | Yellow</pines-table-cell>
            <pines-table-cell>The color scheme.</pines-table-cell>
        </pines-table-row>
        <pines-table-row>
            <pines-table-cell>class</pines-table-cell>
            <pines-table-cell>string</pines-table-cell>
            <pines-table-cell>Additional CSS classes added at the top level of the component.</pines-table-cell>
        </pines-table-row>
        <pines-table-row>
            <pines-table-cell>header</pines-table-cell>
            <pines-table-cell>string</pines-table-cell>
            <pines-table-cell>The alert headline text.</pines-table-cell>
        </pines-table-row>
    </tbody>
</pines-table>
<p class="text-neutral-500 text-sm mt-2 mb-8">This uses child content as a primary form of content display.</p>