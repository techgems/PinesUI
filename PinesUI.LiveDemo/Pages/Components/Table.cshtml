@page
@using System.Text
@using TechGems.PinesUI.Views.Components.PinesTabs
@model PinesUI.LiveDemo.Pages.Components.TableModel

@{
    ViewData["Title"] = "Table";

    var tabConfig = new Dictionary<string, PinesTabConfigItem>()
    {
        { "Preview", new PinesTabConfigItem { TabName = "Preview", Order = 1 } },
        { "Code", new PinesTabConfigItem { TabName = "Code", Order = 2 } },
    };

    var columns = new List<(string Name, string DisplayName)>()
    {
        ("Name", "Name"),
        ("Email", "Email"),
        ("Role", "Role"),
    };

    var tableData = new List<object>()
    {
        new { Name = "John Doe", Email = "john@example.com", Role = "Admin" },
        new { Name = "Jane Smith", Email = "jane@example.com", Role = "Editor" },
        new { Name = "Bob Wilson", Email = "bob@example.com", Role = "Viewer" },
    };

    StringBuilder codeCreator = new StringBuilder();
    codeCreator.AppendLine(@"  @{");
    codeCreator.AppendLine(@"      var columns = new List<(string Name, string DisplayName)>()");
    codeCreator.AppendLine(@"      {");
    codeCreator.AppendLine(@"          (""Name"", ""Name""),");
    codeCreator.AppendLine(@"          (""Email"", ""Email""),");
    codeCreator.AppendLine(@"          (""Role"", ""Role""),");
    codeCreator.AppendLine(@"      };");
    codeCreator.AppendLine(@"");
    codeCreator.AppendLine(@"      var tableData = new List<object>()");
    codeCreator.AppendLine(@"      {");
    codeCreator.AppendLine(@"          new { Name = ""John Doe"", Email = ""john@example.com"", Role = ""Admin"" },");
    codeCreator.AppendLine(@"          new { Name = ""Jane Smith"", Email = ""jane@example.com"", Role = ""Editor"" },");
    codeCreator.AppendLine(@"          new { Name = ""Bob Wilson"", Email = ""bob@example.com"", Role = ""Viewer"" },");
    codeCreator.AppendLine(@"      };");
    codeCreator.AppendLine(@"  }");
    codeCreator.AppendLine(@"");
    codeCreator.AppendLine(@"  <pines-table table-id=""demo-table"" column-config=""columns"" data=""tableData""></pines-table>");

    var tableCode = codeCreator.ToString();
    codeCreator.Clear();

}

<h2>Table</h2>
<p class="text-neutral-500 mb-5">Data tables for displaying structured tabular information.</p>

<h3>Table</h3>

<pines-tabs tab-config="tabConfig">
    <slot name="Preview">
        <pines-table table-id="demo-table" column-config="columns" data="tableData"></pines-table>
    </slot>
    <slot name="Code">
        <code-highlight lang="html" code="@tableCode"></code-highlight>
    </slot>
</pines-tabs>

<h3>Parameters</h3>
<pines-table table-id="table-params">
    <pines-table-header>
        <pines-table-cell is-header="true">Attribute</pines-table-cell>
        <pines-table-cell is-header="true">Type</pines-table-cell>
        <pines-table-cell is-header="true">Default</pines-table-cell>
        <pines-table-cell is-header="true">Description</pines-table-cell>
    </pines-table-header>
    <tbody class="divide-y divide-neutral-200">
        <pines-table-row>
            <pines-table-cell>table-id</pines-table-cell>
            <pines-table-cell>string?</pines-table-cell>
            <pines-table-cell>N/A</pines-table-cell>
            <pines-table-cell>HTML id attribute for the table element.</pines-table-cell>
        </pines-table-row>
        <pines-table-row>
            <pines-table-cell>column-config</pines-table-cell>
            <pines-table-cell>List&lt;(string, string)&gt;</pines-table-cell>
            <pines-table-cell>new List&lt;&gt;()</pines-table-cell>
            <pines-table-cell>Column definitions (property name and display header).</pines-table-cell>
        </pines-table-row>
        <pines-table-row>
            <pines-table-cell>data</pines-table-cell>
            <pines-table-cell>List&lt;object&gt;</pines-table-cell>
            <pines-table-cell>new List&lt;&gt;()</pines-table-cell>
            <pines-table-cell>Row data objects (properties matched by column Name).</pines-table-cell>
        </pines-table-row>
        <pines-table-row>
            <pines-table-cell>display-action-col</pines-table-cell>
            <pines-table-cell>bool</pines-table-cell>
            <pines-table-cell>false</pines-table-cell>
            <pines-table-cell>Whether to render an action column.</pines-table-cell>
        </pines-table-row>
    </tbody>
</pines-table>
