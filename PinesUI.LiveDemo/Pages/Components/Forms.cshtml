@page
@using System.Text
@using TechGems.PinesUI.Views.Components.PinesTabs
@model PinesUI.LiveDemo.Pages.Components.FormsModel

@{
    ViewData["Title"] = "Forms";

    var tabConfig = new Dictionary<string, PinesTabConfigItem>()
    {
        { "Preview", new PinesTabConfigItem { TabName = "Preview", Order = 1 } },
        { "Code", new PinesTabConfigItem { TabName = "Code", Order = 2 } },
    };

    // Input code
    StringBuilder codeCreator = new StringBuilder();
    codeCreator.AppendLine(@"  <pines-input show-label=""true"" asp-for=""YourModel.Name""></pines-input>");
    codeCreator.AppendLine(@"");
    codeCreator.AppendLine(@"  <pines-input show-label=""true"" disabled=""true"" asp-for=""YourModel.Email""></pines-input>");
    var inputCode = codeCreator.ToString();
    codeCreator.Clear();

    // Switch code
    codeCreator.AppendLine(@"  <pines-switch label=""Enable notifications""></pines-switch>");
    codeCreator.AppendLine(@"");
    codeCreator.AppendLine(@"  <pines-switch label=""Dark mode"" switch-on=""true""></pines-switch>");
    var switchCode = codeCreator.ToString();
    codeCreator.Clear();

    // Select code
    codeCreator.AppendLine(@"  @{");
    codeCreator.AppendLine(@"      var selectItems = new List<PinesSelectItem>()");
    codeCreator.AppendLine(@"      {");
    codeCreator.AppendLine(@"          new PinesSelectItem { Title = ""Apple"", Value = ""apple"" },");
    codeCreator.AppendLine(@"          new PinesSelectItem { Title = ""Banana"", Value = ""banana"" },");
    codeCreator.AppendLine(@"          new PinesSelectItem { Title = ""Cherry"", Value = ""cherry"" },");
    codeCreator.AppendLine(@"          new PinesSelectItem { Title = ""Grape"", Value = ""grape"", Disabled = true },");
    codeCreator.AppendLine(@"      };");
    codeCreator.AppendLine(@"  }");
    codeCreator.AppendLine(@"");
    codeCreator.AppendLine(@"  <pines-select items=""selectItems"" placeholder=""Choose a fruit""></pines-select>");
    var selectCode = codeCreator.ToString();
    codeCreator.Clear();

    // DatePicker code
    codeCreator.AppendLine(@"  <pines-date-picker label=""Event Date"" placeholder=""Pick a date""></pines-date-picker>");
    codeCreator.AppendLine(@"");
    codeCreator.AppendLine(@"  <pines-date-picker label=""ISO Format"" date-format=""YYYY-MM-DD""></pines-date-picker>");
    var datePickerCode = codeCreator.ToString();
    codeCreator.Clear();

}

<h2>Forms</h2>
<p class="text-neutral-500 mb-5">Form input elements including text inputs, switches, selects, and date pickers.</p>

<h3>Input</h3>

<pines-tabs tab-config="tabConfig">
    <slot name="Preview">
        <div class="flex flex-col gap-4 max-w-sm">
            <pines-input show-label="true"></pines-input>
        </div>
    </slot>
    <slot name="Code">
        <code-highlight lang="html" code="@inputCode"></code-highlight>
    </slot>
</pines-tabs>

<h3>Parameters — <code>&lt;pines-input&gt;</code></h3>
<pines-table table-id="input-params">
    <pines-table-header>
        <pines-table-cell is-header="true">Attribute</pines-table-cell>
        <pines-table-cell is-header="true">Type</pines-table-cell>
        <pines-table-cell is-header="true">Description</pines-table-cell>
    </pines-table-header>
    <tbody class="divide-y divide-neutral-200">
        <pines-table-row>
            <pines-table-cell>asp-for</pines-table-cell>
            <pines-table-cell>ModelExpression?</pines-table-cell>
            <pines-table-cell>Model binding expression.</pines-table-cell>
        </pines-table-row>
        <pines-table-row>
            <pines-table-cell>show-label</pines-table-cell>
            <pines-table-cell>bool</pines-table-cell>
            <pines-table-cell>Whether to display the field label.</pines-table-cell>
        </pines-table-row>
        <pines-table-row>
            <pines-table-cell>disabled</pines-table-cell>
            <pines-table-cell>bool</pines-table-cell>
            <pines-table-cell>Whether the input is disabled.</pines-table-cell>
        </pines-table-row>
    </tbody>
</pines-table>


<h3>Switch</h3>

<pines-tabs tab-config="tabConfig">
    <slot name="Preview">
        <div class="flex flex-col gap-4">
            <pines-switch label="Enable notifications"></pines-switch>
            <pines-switch label="Dark mode" switch-on="true"></pines-switch>
        </div>
    </slot>
    <slot name="Code">
        <code-highlight lang="html" code="@switchCode"></code-highlight>
    </slot>
</pines-tabs>


<h3>Parameters — <code>&lt;pines-switch&gt;</code></h3>
<pines-table table-id="switch-params">
    <pines-table-header>
        <pines-table-cell is-header="true">Attribute</pines-table-cell>
        <pines-table-cell is-header="true">Type</pines-table-cell>
        <pines-table-cell is-header="true">Description</pines-table-cell>
    </pines-table-header>
    <tbody class="divide-y divide-neutral-200">
        <pines-table-row>
            <pines-table-cell>label</pines-table-cell>
            <pines-table-cell>string</pines-table-cell>
            <pines-table-cell>Label text displayed beside the switch.</pines-table-cell>
        </pines-table-row>
        <pines-table-row>
            <pines-table-cell>asp-for</pines-table-cell>
            <pines-table-cell>ModelExpression?</pines-table-cell>
            <pines-table-cell>Model binding expression.</pines-table-cell>
        </pines-table-row>
        <pines-table-row>
            <pines-table-cell>switch-on</pines-table-cell>
            <pines-table-cell>bool</pines-table-cell>
            <pines-table-cell>Initial toggle state.</pines-table-cell>
        </pines-table-row>
    </tbody>
</pines-table>

@{
    var selectItems = new List<TechGems.PinesUI.Views.Components.PinesSelect.PinesSelectItem>()
    {
        new TechGems.PinesUI.Views.Components.PinesSelect.PinesSelectItem { Title = "Apple", Value = "apple" },
        new TechGems.PinesUI.Views.Components.PinesSelect.PinesSelectItem { Title = "Banana", Value = "banana" },
        new TechGems.PinesUI.Views.Components.PinesSelect.PinesSelectItem { Title = "Cherry", Value = "cherry" },
        new TechGems.PinesUI.Views.Components.PinesSelect.PinesSelectItem { Title = "Grape", Value = "grape", Disabled = true },
    };
}

<h3>Select</h3>

<pines-tabs tab-config="tabConfig">
    <slot name="Preview">
        <div class="max-w-sm">
            <pines-select items="selectItems" placeholder="Choose a fruit"></pines-select>
        </div>
    </slot>
    <slot name="Code">
        <code-highlight lang="html" code="@selectCode"></code-highlight>
    </slot>
</pines-tabs>

<h3>Parameters — <code>&lt;pines-select&gt;</code></h3>
<pines-table table-id="select-params">
    <pines-table-header>
        <pines-table-cell is-header="true">Attribute</pines-table-cell>
        <pines-table-cell is-header="true">Type</pines-table-cell>
        <pines-table-cell is-header="true">Description</pines-table-cell>
    </pines-table-header>
    <tbody class="divide-y divide-neutral-200">
        <pines-table-row>
            <pines-table-cell>items</pines-table-cell>
            <pines-table-cell>
                <code>List&lt;PinesSelectItem&gt;</code>
            </pines-table-cell>
            <pines-table-cell>The selectable options.</pines-table-cell>
        </pines-table-row>
        <pines-table-row>
            <pines-table-cell>placeholder</pines-table-cell>
            <pines-table-cell>string</pines-table-cell>
            <pines-table-cell>Placeholder text.</pines-table-cell>
        </pines-table-row>
        <pines-table-row>
            <pines-table-cell>asp-for</pines-table-cell>
            <pines-table-cell>ModelExpression?</pines-table-cell>
            <pines-table-cell>Model binding expression.</pines-table-cell>
        </pines-table-row>
    </tbody>
</pines-table>

<h4><code>PinesSelectItem</code> Properties</h4>
<pines-table table-id="select-item-props">
    <pines-table-header>
        <pines-table-cell is-header="true">Property</pines-table-cell>
        <pines-table-cell is-header="true">Type</pines-table-cell>
        <pines-table-cell is-header="true">Description</pines-table-cell>
    </pines-table-header>
    <tbody class="divide-y divide-neutral-200">
        <pines-table-row>
            <pines-table-cell>Title</pines-table-cell>
            <pines-table-cell>string</pines-table-cell>
            <pines-table-cell>Display text.</pines-table-cell>
        </pines-table-row>
        <pines-table-row>
            <pines-table-cell>Value</pines-table-cell>
            <pines-table-cell>string</pines-table-cell>
            <pines-table-cell>Form value.</pines-table-cell>
        </pines-table-row>
        <pines-table-row>
            <pines-table-cell>Disabled</pines-table-cell>
            <pines-table-cell>bool</pines-table-cell>
            <pines-table-cell>Whether the option is disabled.</pines-table-cell>
        </pines-table-row>
    </tbody>
</pines-table>

<h3>Date Picker</h3>

<pines-tabs tab-config="tabConfig">
    <slot name="Preview">
        <div class="flex flex-col gap-6">
            <pines-date-picker label="Event Date" placeholder="Pick a date"></pines-date-picker>
            <pines-date-picker label="ISO Format" date-format="YYYY-MM-DD"></pines-date-picker>
        </div>
    </slot>
    <slot name="Code">
        <code-highlight lang="html" code="@datePickerCode"></code-highlight>
    </slot>
</pines-tabs>

