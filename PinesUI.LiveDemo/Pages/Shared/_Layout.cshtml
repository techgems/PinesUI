@using TechGems.PinesUI.Views.Components.PinesSidebar
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.tailwind.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PinesUI.LiveDemo.styles.css" asp-append-version="true" />
    <link href="~/css/atom-one-dark.css" rel="stylesheet" />
    <pines-css />
</head>
<body class="bg-white antialiased">

    @* Top navigation bar *@
    <pines-navbar home-route="/">
        <slot name="nav-links">
            <pines-sidebar-link asp-page="/Index">Home</pines-sidebar-link>
        </slot>
        <slot name="user-area">
        </slot>
    </pines-navbar>

    @* Page body: sidebar + main content *@
    <div class="relative flex items-start min-h-screen px-4 pt-0 pb-0 mx-auto mt-16 max-w-7xl">

        @* Mobile overlay to close sidebar *@
        <pines-backdrop-blur></pines-backdrop-blur>

        @* Left sidebar *@
        <pines-sidebar>
            <pines-sidebar-section section-name="Getting Started">
                <pines-sidebar-link asp-page="/Index">Home</pines-sidebar-link>
                <pines-sidebar-link asp-page="/Introduction/Installation">Installation</pines-sidebar-link>
            </pines-sidebar-section>
            <pines-sidebar-section section-name="Elements">
                <pines-sidebar-link asp-page="/Components/Alerts">Alerts</pines-sidebar-link>
                <pines-sidebar-link asp-page="/Components/Badge">Badge</pines-sidebar-link>
                <pines-sidebar-link asp-page="/Components/Banner">Banner</pines-sidebar-link>
                <pines-sidebar-link asp-page="/Components/Breadcrumbs">Breadcrumbs</pines-sidebar-link>
                <pines-sidebar-link asp-page="/Components/Buttons">Buttons</pines-sidebar-link>
                <pines-sidebar-link asp-page="/Components/Cards">Cards</pines-sidebar-link>
                <pines-sidebar-link asp-page="/Components/DropdownMenu">Dropdown Menu</pines-sidebar-link>
                <pines-sidebar-link asp-page="/Components/Forms">Forms</pines-sidebar-link>
                <pines-sidebar-link asp-page="/Components/Icon">Icon</pines-sidebar-link>
                <pines-sidebar-link asp-page="/Components/ImageGallery">Image Gallery</pines-sidebar-link>
                <pines-sidebar-link asp-page="/Components/Marquee">Marquee</pines-sidebar-link>
                <pines-sidebar-link asp-page="/Components/Modal">Modal</pines-sidebar-link>
                <pines-sidebar-link asp-page="/Components/Quote">Quote</pines-sidebar-link>
                <pines-sidebar-link asp-page="/Components/Rating">Rating</pines-sidebar-link>
                <pines-sidebar-link asp-page="/Components/Table">Table</pines-sidebar-link>
                <pines-sidebar-link asp-page="/Components/Tabs">Tabs</pines-sidebar-link>
                <pines-sidebar-link asp-page="/Components/TextAnimation">Text Animation</pines-sidebar-link>
                <pines-sidebar-link asp-page="/Components/TypingEffect">Typing Effect</pines-sidebar-link>
            </pines-sidebar-section>
        </pines-sidebar>

        @* Main content area — offset by sidebar width on large screens *@
        <main role="main" class="flex-1 w-full min-w-0 pl-0 lg:pl-63 pb-16 pt-5">
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/highlight.min.js"></script>
    <pines-scripts />
    <render-static-scripts />
</body>
</html>
