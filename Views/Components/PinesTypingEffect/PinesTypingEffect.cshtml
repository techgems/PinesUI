@using TechGems.PinesUI.Views.Components.PinesTypingEffect;
@using TechGems.StaticComponents;
@model PinesTypingEffect

<div x-data="pinesTypingEffect(@(JavascriptConvert.SerializeObject(Model.TextArray, true)), @Model.TypeSpeed, @Model.CursorSpeed, @Model.PauseEnd, @Model.PauseStart)"
     class="flex items-center justify-center mx-auto text-center max-w-7xl">
    <div class="relative flex items-center justify-center h-auto">
        <p class="text-2xl font-black leading-tight" x-text="text"></p>
        <span class="absolute right-0 w-2 -mr-2 bg-black h-3/4" x-ref="cursor"></span>
    </div>
</div>

<script static-script type="text/javascript" render-once="Model" teleport-script>
    document.addEventListener('alpine:init', function() {
        Alpine.data('pinesTypingEffect', function(textArray, typeSpeed, cursorSpeed, pauseEnd, pauseStart) {
            return {
                text: '',
                textArray: textArray,
                textIndex: 0,
                charIndex: 0,
                typeSpeed: typeSpeed,
                cursorSpeed: cursorSpeed,
                pauseEnd: pauseEnd,
                pauseStart: pauseStart,
                direction: 'forward',
                init: function() {
                    var self = this;
                    var typingInterval = setInterval(function() { self.startTyping(self, typingInterval); }, self.typeSpeed);

                    setInterval(function() {
                        if (self.$refs.cursor.classList.contains('hidden')) {
                            self.$refs.cursor.classList.remove('hidden');
                        } else {
                            self.$refs.cursor.classList.add('hidden');
                        }
                    }, self.cursorSpeed);
                },
                startTyping: function(self, typingInterval) {
                    var current = self.textArray[self.textIndex];

                    if (self.charIndex > current.length) {
                        self.direction = 'backward';
                        clearInterval(typingInterval);
                        setTimeout(function() {
                            typingInterval = setInterval(function() { self.startTyping(self, typingInterval); }, self.typeSpeed);
                        }, self.pauseEnd);
                    }

                    self.text = current.substring(0, self.charIndex);

                    if (self.direction == 'forward') {
                        self.charIndex += 1;
                    } else {
                        if (self.charIndex == 0) {
                            self.direction = 'forward';
                            clearInterval(typingInterval);
                            setTimeout(function() {
                                self.textIndex += 1;
                                if (self.textIndex >= self.textArray.length) {
                                    self.textIndex = 0;
                                }
                                typingInterval = setInterval(function() { self.startTyping(self, typingInterval); }, self.typeSpeed);
                            }, self.pauseStart);
                        }
                        self.charIndex -= 1;
                    }
                }
            };
        });
    });
</script>
