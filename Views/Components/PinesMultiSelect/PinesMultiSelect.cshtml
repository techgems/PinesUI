@using TechGems.PinesUI.Views.Components.PinesMultiSelect;
@using TechGems.PinesUI.Views.Components.PinesSelect;
@using TechGems.StaticComponents;
@model PinesMultiSelect

@{
    var totalList = JavascriptConvert.SerializeObject(Model.Items, true);
    var selectedList = Model.Values != null ? JavascriptConvert.SerializeObject(Model.Values, true) : null;
}

<div x-data="pinesMultiSelect(@(totalList), @(selectedList))"
     x-init="
        $watch('selectOpen', function(value){
            if(value){
                selectableItemActive = filteredItems().length > 0 ? filteredItems()[0] : null;
                setTimeout(function(){
                    selectScrollToActiveItem();
                }, 10);
                selectPositionUpdate();
                $nextTick(function(){ $refs.searchInput.focus(); });
            }
        });
     "
     @@keydown.escape="if(selectOpen){ selectOpen = false; }"
     @@keydown.down.prevent="if(selectOpen){ selectableItemActiveNext(); } else { selectOpen = true; }"
     @@keydown.up.prevent="if(selectOpen){ selectableItemActivePrevious(); } else { selectOpen = true; }"
     @@keydown.enter.prevent="if(selectOpen && selectableItemActive){ toggleItem(selectableItemActive); }"
     class="relative w-64">

    @if (Model.InputExpression != null)
    {
        <template x-for="item in selectedItems" :key="item.value">
            <input type="hidden" name="@Model.InputExpression.Name" :value="item.value" />
        </template>
    }

    <div x-ref="selectButton" @@click="selectOpen = !selectOpen"
         :class="{ 'ring-2 ring-offset-2 ring-neutral-400' : selectOpen }"
         class="relative flex flex-wrap items-center gap-1 w-full min-h-[38px] py-1.5 pl-2 pr-10 text-left bg-white border rounded-md shadow-sm cursor-default border-neutral-200/70 focus:outline-none text-sm">

        <template x-for="item in selectedItems" :key="item.value">
            <span class="inline-flex items-center gap-1 px-2 py-0.5 text-xs font-medium bg-neutral-100 text-neutral-700 rounded">
                <span x-text="item.title"></span>
                <button type="button" @@click.stop="removeItem(item)" class="text-neutral-400 hover:text-neutral-600 focus:outline-none">
                    <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
                    </svg>
                </button>
            </span>
        </template>

        <span x-show="selectedItems.length === 0" class="text-neutral-400 truncate select-none pl-1">@Model.Placeholder</span>

        <span class="absolute inset-y-0 right-0 flex items-center pr-2 pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-gray-400">
                <path fill-rule="evenodd" d="M10 3a.75.75 0 01.55.24l3.25 3.5a.75.75 0 11-1.1 1.02L10 4.852 7.3 7.76a.75.75 0 01-1.1-1.02l3.25-3.5A.75.75 0 0110 3zm-3.76 9.2a.75.75 0 011.06.04l2.7 2.908 2.7-2.908a.75.75 0 111.1 1.02l-3.25 3.5a.75.75 0 01-1.1 0l-3.25-3.5a.75.75 0 01.04-1.06z" clip-rule="evenodd" />
            </svg>
        </span>
    </div>

    <div x-show="selectOpen"
         x-ref="selectDropdown"
         @@click.away="selectOpen = false"
         x-transition:enter="transition ease-out duration-50"
         x-transition:enter-start="opacity-0 -translate-y-1"
         x-transition:enter-end="opacity-100"
         :class="{ 'bottom-0 mb-10' : selectDropdownPosition == 'top', 'top-0 mt-10' : selectDropdownPosition == 'bottom' }"
         class="absolute w-full mt-1 bg-white rounded-md shadow-md ring-1 ring-black ring-opacity-5 z-50"
         x-cloak>

        <div class="p-2">
            <input x-ref="searchInput"
                   x-model="searchQuery"
                   @@keydown.stop
                   type="text"
                   placeholder="Search..."
                   class="w-full px-2 py-1.5 text-sm border rounded border-neutral-200 focus:outline-none focus:ring-1 focus:ring-neutral-400" />
        </div>

        <ul x-ref="selectableItemsList" class="overflow-auto py-1 text-sm max-h-56 focus:outline-none">
            <template x-for="item in filteredItems()" :key="item.value">
                <li @@click="toggleItem(item); $refs.searchInput.focus();"
                    :id="item.value + '-' + selectId"
                    :data-disabled="item.disabled"
                    :class="{ 'bg-neutral-100 text-gray-900' : selectableItemIsActive(item) }"
                    @@mousemove="selectableItemActive = item"
                    class="relative flex items-center h-full py-2 pl-8 text-gray-700 cursor-default select-none data-[disabled]:opacity-50 data-[disabled]:pointer-events-none">
                    <svg x-show="isSelected(item)" class="absolute left-0 w-4 h-4 ml-2 stroke-current text-neutral-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    <span class="block font-medium truncate" x-text="item.title"></span>
                </li>
            </template>
            <li x-show="filteredItems().length === 0" class="py-2 pl-8 text-gray-400 select-none">No results found</li>
        </ul>
    </div>
</div>

<script static-script type="text/javascript" render-once="Model" teleport-script>
    document.addEventListener('alpine:init', function() {
        Alpine.data('pinesMultiSelect', function(items, selectedItems) {
            return {
                selectOpen: false,
                selectedItems: selectedItems || [],
                searchQuery: '',
                selectableItems: items,
                selectableItemActive: null,
                selectId: this.$id('multiselect'),
                selectDropdownPosition: 'bottom',
                isSelected: function(item) {
                    return this.selectedItems.some(function(s) { return s.value === item.value; });
                },
                toggleItem: function(item) {
                    if (item.disabled) return;
                    var index = this.selectedItems.findIndex(function(s) { return s.value === item.value; });
                    if (index > -1) {
                        this.selectedItems.splice(index, 1);
                    } else {
                        this.selectedItems.push(item);
                    }
                },
                removeItem: function(item) {
                    this.selectedItems = this.selectedItems.filter(function(s) { return s.value !== item.value; });
                },
                filteredItems: function() {
                    var query = this.searchQuery.toLowerCase();
                    if (!query) return this.selectableItems;
                    return this.selectableItems.filter(function(item) {
                        return item.title.toLowerCase().indexOf(query) > -1;
                    });
                },
                selectableItemIsActive: function(item) {
                    return this.selectableItemActive && this.selectableItemActive.value === item.value;
                },
                selectableItemActiveNext: function() {
                    var items = this.filteredItems();
                    var index = items.indexOf(this.selectableItemActive);
                    if (index < items.length - 1) {
                        this.selectableItemActive = items[index + 1];
                        this.selectScrollToActiveItem();
                    }
                },
                selectableItemActivePrevious: function() {
                    var items = this.filteredItems();
                    var index = items.indexOf(this.selectableItemActive);
                    if (index > 0) {
                        this.selectableItemActive = items[index - 1];
                        this.selectScrollToActiveItem();
                    }
                },
                selectScrollToActiveItem: function() {
                    if (this.selectableItemActive) {
                        var activeElement = document.getElementById(this.selectableItemActive.value + '-' + this.selectId);
                        if (activeElement) {
                            var newScrollPos = (activeElement.offsetTop + activeElement.offsetHeight) - this.$refs.selectableItemsList.offsetHeight;
                            if (newScrollPos > 0) {
                                this.$refs.selectableItemsList.scrollTop = newScrollPos;
                            } else {
                                this.$refs.selectableItemsList.scrollTop = 0;
                            }
                        }
                    }
                },
                selectPositionUpdate: function() {
                    var buttonRect = this.$refs.selectButton.getBoundingClientRect();
                    var dropdownMaxHeight = parseInt(window.getComputedStyle(this.$refs.selectableItemsList).maxHeight) + 60;
                    var selectDropdownBottomPos = buttonRect.top + buttonRect.height + dropdownMaxHeight;
                    if (window.innerHeight < selectDropdownBottomPos) {
                        this.selectDropdownPosition = 'top';
                    } else {
                        this.selectDropdownPosition = 'bottom';
                    }
                }
            };
        });
    });
</script>
