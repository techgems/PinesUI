@using TechGems.PinesUI.Views.Components.PinesAlert
@model PinesAlert

@{
    var colorClass = Model switch
    {
        { AlertColor: PinesAlertColorEnum.Blue, AlertType: PinesAlertTypeEnum.Primary } => "bg-blue-600 text-white border-transparent",
        { AlertColor: PinesAlertColorEnum.Green, AlertType: PinesAlertTypeEnum.Primary } => "bg-green-600 text-white border-transparent",
        { AlertColor: PinesAlertColorEnum.Yellow, AlertType: PinesAlertTypeEnum.Primary } => "bg-yellow-600 text-white border-transparent",
        { AlertColor: PinesAlertColorEnum.Red, AlertType: PinesAlertTypeEnum.Primary } => "bg-red-600 text-white border-transparent",
        { AlertColor: PinesAlertColorEnum.Blue, AlertType: PinesAlertTypeEnum.Secondary } => "bg-blue-50 text-blue-600 border-transparent",
        { AlertColor: PinesAlertColorEnum.Green, AlertType: PinesAlertTypeEnum.Secondary } => "bg-green-50 text-green-600 border-transparent",
        { AlertColor: PinesAlertColorEnum.Yellow, AlertType: PinesAlertTypeEnum.Secondary } => "bg-yellow-50 text-yellow-600 border-transparent",
        { AlertColor: PinesAlertColorEnum.Red, AlertType: PinesAlertTypeEnum.Secondary } => "bg-red-50 text-red-600 border-transparent",
        { AlertType: PinesAlertTypeEnum.Neutral } => "bg-white text-neutral-900",
        _ => ""
    };

    var sharedClass = "relative w-full rounded-lg border p-4";
}

<div class="@sharedClass @colorClass @Model.Class">
    <div class="flex">
        @if (PinesAlertColorEnum.Blue == Model.AlertColor)
        {
            <svg class="w-5 h-5 -translate-y-0.5 my-auto mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" /></svg>
        }
        else if (PinesAlertColorEnum.Red == Model.AlertColor)
        {
            <svg class="w-5 h-5 -translate-y-0.5 my-auto mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" /></svg>
        }
        else if (PinesAlertColorEnum.Green == Model.AlertColor)
        {
            <svg class="w-5 h-5 -translate-y-0.5 my-auto mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        }
        else if (PinesAlertColorEnum.Yellow == Model.AlertColor)
        {
            <svg class="w-5 h-5 -translate-y-0.5 my-auto mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" /></svg>
        }
        <h5 class="mb-1 font-medium leading-none tracking-tight">@Model.Header</h5>
    </div>
    
    <div class="text-sm opacity-80">@Model.ChildContent</div>
</div>